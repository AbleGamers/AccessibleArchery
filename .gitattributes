# Normalize line endings.
* text=auto eol=lf

# Godot text resources merge more sanely as plain text.
*.gd     text
*.tscn   text
*.tres   text
*.godot  text
*.cfg    text

# Treat common binary asset types as binary.
*.png    binary
*.jpg    binary
*.webp   binary
*.ogg    binary
*.wav    binary
*.mp3    binary
*.glb    binary
